# Variáveis de ambiente — copie para .env e preencha os valores reais

# ── PostgreSQL (Railway plugin) ─────────────────────
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Redis (Railway plugin) ──────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── Gateway ─────────────────────────────────────────
JWT_SECRET=troque-por-um-secret-longo-e-aleatorio-minimo-64-chars
CORS_ORIGINS=https://hub.plamevbrasil.com.br
EVOLUTION_WEBHOOK_SECRET=

# ── URLs internas (Railway private network) ─────────
CHANNEL_SERVICE_URL=http://channel-service:3002
AGENT_AI_URL=http://agent-ai:3001
CRM_SERVICE_URL=http://crm-service:3003
ANALYTICS_URL=http://analytics:3004

# ── Channel Service ─────────────────────────────────
EVOLUTION_API_URL=https://legendarios-evolution-api.bycpkh.easypanel.host
EVOLUTION_API_KEY=
TELEGRAM_TOKEN=

# ── Agent AI ────────────────────────────────────────
ANTHROPIC_API_KEY=         # gerar nova key em console.anthropic.com
OPENAI_API_KEY=            # opcional — fallback multi-provider
VOYAGE_API_KEY=            # para embeddings e reranking

# ── Frontend ─────────────────────────────────────────
VITE_API_URL=https://hub.plamevbrasil.com.br
VITE_WS_URL=wss://hub.plamevbrasil.com.br
