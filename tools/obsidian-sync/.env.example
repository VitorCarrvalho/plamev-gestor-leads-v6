# URL pública do PostgreSQL no Railway
# Railway → seu projeto → PostgreSQL → Connect → "Public Network"
DATABASE_URL=postgresql://postgres:senha@junction.proxy.rlwy.net:XXXXX/railway

# ID do agente no banco (agentes.id)
AGENT_ID=1

# Caminho absoluto até a pasta do vault no Obsidian
OBSIDIAN_VAULT_PATH=/Users/vitor/Documents/Obsidian

# Pasta dentro do vault que contém os arquivos de soul/prompts
# Os arquivos devem ter o nome exato mapeado abaixo (ver PROMPT_MAP no index.js)
PROMPTS_FOLDER=Plamev/Mari

# Pasta dentro do vault que contém a base de conhecimento
# Subpastas viram o campo "pasta" no banco; arquivos viram "arquivo"
KB_FOLDER=Plamev/Base de Conhecimento
