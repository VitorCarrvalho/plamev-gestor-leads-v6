# Caminho absoluto até a pasta raiz do vault no Obsidian (local)
OBSIDIAN_VAULT_PATH=/Users/vitor/Documents/Obsidian/Plamev

# Caminho absoluto até a pasta vault-server no repositório local
# Os arquivos são copiados daqui antes do git commit + push
REPO_VAULT_PATH=/Users/vitor/Documents/Plamev/workspace/plamev-gestor-leads-v6/services/vault-server/vault

# URL pública do agent-ai no Railway (opcional — ativa sync RAG após push de conteúdo não-Mari)
# Ex: https://agent-ai-production-xxxx.up.railway.app
AGENT_AI_URL=

# Secret compartilhado para autenticar chamadas internas (deve coincidir com INTERNAL_SECRET no agent-ai)
INTERNAL_SECRET=plamev-internal

# ID do agente a sincronizar (padrão: 1)
AGENT_ID=1
